# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
# Anchored, so it only matches .next at the repo root. Build output inside
# nested worktrees is covered by the .claude/ rule below.
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# Claude Code local state: agent definitions, local settings, and worktrees.
# The worktrees hold their own .next build output, which the anchored /.next/
# rule above does not catch, so a stray `git add -A` would otherwise commit
# thousands of build artifacts.
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts
